# ClawWallet Agent Configuration
# Copy to .env and fill in values

# Seed phrase (24 words) — KEEP SECRET
# Leave empty to auto-generate on first run
SEED_PHRASE=

# EVM RPC providers
ETH_RPC=https://eth.drpc.org
POLYGON_RPC=https://polygon-rpc.com
BSC_RPC=https://bsc-dataseed.binance.org

# Bitcoin provider
BTC_PROVIDER=https://blockstream.info/api

# Solana RPC
SOL_RPC=https://api.mainnet-beta.solana.com

# Safety limits (USD)
MAX_SINGLE_TX_USD=100
DAILY_TX_LIMIT_USD=1000
REQUIRE_CONFIRMATION_ABOVE_USD=50

# Agent mode: interactive | demo
AGENT_MODE=demo

# Logging
LOG_LEVEL=info
